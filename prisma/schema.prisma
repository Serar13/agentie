generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  articles    NewsArticle[]
  sources     Source[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model NewsArticle {
  id              String             @id @default(cuid())
  title           String
  slug            String             @unique
  subtitle        String?
  lead            String
  content         String
  imageUrl        String?
  categoryId      String
  category        Category           @relation(fields: [categoryId], references: [id])
  status          String             @default("draft")
  positiveScore   Int                @default(0)
  confidenceScore Int                @default(0)
  sourceQualityScore Int             @default(0)
  originalityScore   Int             @default(0)
  editorialScore     Int             @default(0)
  riskLevel          String          @default("low") // "low" | "medium" | "high"
  rejectionReason    String?
  editorNotes        String?
  reviewedBy         String?
  reviewHistory      String?         // JSON string
  qualityNotes    String?
  seoTitle        String?
  metaDescription String?
  socialFacebook  String?
  socialInstagram String?
  socialLinkedin  String?
  socialTiktok    String?
  socialYoutube   String?
  socialVideoHooks String?         // JSON or text
  socialReelText  String?
  socialHashtags  String?
  newsletterBlurb String?
  originalUrl     String?
  sourceName      String?
  scannedAt       DateTime?
  approvedAt      DateTime?
  publishedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  references      ArticleReference[]
  costs           CostLog[]

  @@index([categoryId])
  @@index([slug])
  @@index([status])
}

model ArticleReference {
  id                 String      @id @default(cuid())
  articleId          String
  article            NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  title              String
  outlet             String
  url                String
  verified           Boolean     @default(false)
  checkedAt          DateTime?
  contradictionNotes String?
  createdAt          DateTime    @default(now())

  @@index([articleId])
}

model Source {
  id                String    @id @default(cuid())
  name              String
  type              String    @default("rss") // "rss" | "manual"
  url               String    @unique
  status            String    @default("active") // "active" | "paused" | "blocked"
  categoryId        String?
  category          Category? @relation(fields: [categoryId], references: [id])
  trustScore        Int       @default(70)
  scanFrequencyMin  Int       @default(60) // in minutes
  lastScannedAt     DateTime?
  articlesExtracted Int       @default(0)
  articlesAccepted  Int       @default(0)
  articlesRejected  Int       @default(0)
  blacklistKeywords String    @default("") // comma separated
  whitelistKeywords String    @default("") // comma separated
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([categoryId])
}

model ScanCache {
  id          String   @id @default(cuid())
  urlHash     String   @unique
  originalUrl String
  fetchedAt   DateTime @default(now())
  expiresAt   DateTime
  payload     String
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("website")
  status    String   @default("active") // "active" | "unsubscribed"
  createdAt DateTime @default(now())
}

model CommunitySubmission {
  id             String    @id @default(cuid())
  title          String
  description    String
  category       String
  location       String    // oras/judet
  sourceLink     String
  contactName    String
  contactEmail   String
  optionalLinks  String?
  contactConsent Boolean   @default(false)
  status         String    @default("submitted") // "submitted" | "under_review" | "converted_to_article" | "rejected"
  aiAnalysis     String?   // JSON or text with AI findings
  articleId      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Newsletter {
  id          String   @id @default(cuid())
  subject     String
  intro       String
  articles    String   // JSON array of news article IDs
  sentAt      DateTime?
  status      String   @default("draft") // "draft" | "sent"
  type        String   @default("daily") // "daily" | "weekly"
  createdAt   DateTime @default(now())
}

model Donation {
  id          String   @id @default(cuid())
  amount      Float
  currency    String   @default("EUR")
  email       String
  name        String?
  isPublic    Boolean  @default(false)
  status      String   @default("pending") // "pending" | "completed" | "failed"
  providerId  String?  // Stripe charge/payment intent ID
  isFounder   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Member {
  id         String    @id @default(cuid())
  email      String    @unique
  name       String?
  isPublic   Boolean   @default(false)
  status     String    @default("active") // "active" | "paused" | "canceled"
  plan       String    // "monthly_3" | "monthly_5" | "monthly_10"
  providerId String?   // Stripe subscription ID
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  name               String?
  location           String?            // oras/judet
  followedCategories String             @default("") // comma separated slugs
  savedArticles      String             @default("") // comma separated IDs
  newsletterOptIn    Boolean            @default(true)
  role               String             @default("reader") // "reader" | "admin"
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  eventType  String   // "view" | "share" | "newsletter_subscribe" | "donation"
  articleId  String?
  category   String?
  source     String?
  readingTime Int?     // in seconds
  createdAt  DateTime @default(now())
}

model CostLog {
  id               String       @id @default(cuid())
  articleId        String?
  article          NewsArticle? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  agentName        String
  model            String
  inputTokens      Int
  outputTokens     Int
  estimatedCostEur Float
  createdAt        DateTime     @default(now())

  @@index([articleId])
  @@index([createdAt])
}
