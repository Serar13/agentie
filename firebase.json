{
  "apphosting": {
    "backendId": "positive-news-agency",
    "rootDir": "/",
    "ignore": [
      "node_modules",
      ".git",
      ".next",
      ".env",
      ".env.local",
      ".env*.local"
    ]
  },
  "storage": {
    "rules": "storage.rules"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "emulators": {
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}
