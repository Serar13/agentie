{
  "name": "positive-news-agency",
  "version": "0.1.0",
  "private": true,
  "description": "MVP pentru o agentie premium de stiri pozitive, verificate si aprobate manual.",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "DATABASE_URL=file:./db/generated-only.db prisma generate && next build",
    "lint": "eslint . --ext .ts,.tsx",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "scan:sources": "tsx scripts/scan-sources.ts",
    "generate:news": "tsx scripts/generate-news.ts",
    "cost:report": "tsx scripts/cost-report.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "fast-xml-parser": "^4.5.0",
    "firebase-admin": "^14.1.0",
    "next": "^15.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.16.0",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.3.4",
    "postcss": "^8.4.49",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
