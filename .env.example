# Database Provider
# "sqlite"   -> Uses local SQLite database via Prisma (Runs out-of-the-box, recommended for local dev)
# "firebase" -> Uses Firebase Firestore (Requires credentials or local emulator running)
DATA_PROVIDER="sqlite"
DATABASE_URL="file:../db/dev.db"

# Firebase Config (Only needed if DATA_PROVIDER="firebase")
# 1. For local Firebase emulator:
# FIRESTORE_EMULATOR_HOST="127.0.0.1:8080"
# 2. For real Firebase connection:
# FIREBASE_SERVICE_ACCOUNT_JSON='{ ...your JSON credentials... }'
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"


OPENAI_API_KEY=""
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
DEEPSEEK_API_KEY=""

DEFAULT_CHEAP_MODEL="gpt-4o-mini"
DEFAULT_WRITER_MODEL="gpt-4o-mini"
DEFAULT_EDITOR_MODEL="gpt-4o"
DEFAULT_FACTCHECK_MODEL="gpt-4o-mini"

MODEL_PROVIDER="mock"
MONTHLY_BUDGET_EUR="100"
TARGET_MONTHLY_ARTICLES="525"
NEXT_PUBLIC_APP_URL="https://positive-news-agency--positivenews-c6511.us-central1.hosted.app"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="positivenews-c6511"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
